                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Profile contains employee identity', function () {",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data).to.have.property('employee_code');",
                  "    pm.expect(json.data).to.have.property('full_name');",
                  "    pm.expect(json.data).to.have.property('email');",
                  "    pm.expect(json.data).to.have.property('roles');",
                  "    pm.expect(json.data).to.have.property('permissions');",
